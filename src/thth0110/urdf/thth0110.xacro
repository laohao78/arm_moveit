  <!-- Transmissions for ROS Control -->
  <xacro:macro name="transmission_block" params="joint_name">
    <transmission name="tran_${joint_name}"> <!-- 关联关节名-传动名 -->
      <type>transmission_interface/SimpleTransmission</type><!-- 简单传动 -->
      <joint name="${joint_name}">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><!-- 位置控制接口 -->
      </joint>
      <actuator name="motor_${joint_name}"> <!-- 关联关节名-电机名 -->
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><!-- 位置控制接口-必须保持一致 -->
        <mechanicalReduction>1</mechanicalReduction><!-- 机械减速比-1表示无减速比 -->
      </actuator>
    </transmission>
  </xacro:macro>

  <xacro:transmission_block joint_name="j1"/>
  <xacro:transmission_block joint_name="j2"/>
  <xacro:transmission_block joint_name="j3"/>
  <xacro:transmission_block joint_name="j4"/>
  <xacro:transmission_block joint_name="j5"/>
  <xacro:transmission_block joint_name="j6"/><!-- 移动副 -->
  <xacro:transmission_block joint_name="j7"/>
  <xacro:transmission_block joint_name="j8"/><!-- 夹爪主副 -->
  

  <!-- ros_control plugin -->
  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/thth0110</robotNamespace>
      <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
      <legacyModeNS>true</legacyModeNS>
    </plugin>
  </gazebo>

  <!-- Mimic joint plugin for j9 mimicking j8 -->
  <gazebo>
    <plugin name="mimic_joint_plugin_j9" filename="libroboticsgroup_gazebo_mimic_joint_plugin.so">
      <joint>j8</joint>
      <mimicJoint>j9</mimicJoint>
      <multiplier>-1.0</multiplier>
      <offset>0.0</offset>
    </plugin>
  </gazebo>

  <!-- Gazebo plugin for depth camera -->
  <gazebo reference="camera_Link">
    <sensor type="depth" name="d455_depth">
      <update_rate>30.0</update_rate>
      <camera>
        <horizontal_fov>1.658</horizontal_fov> <!-- ～95 deg -->
        <image>
          <width>1280</width>
          <height>720</height>
          <!-- 移除 format，让插件自动处理 RGB 和 Depth -->
        </image>
        <clip>
          <near>0.4</near>
          <far>10.0</far>
        </clip>
      </camera>
      <plugin name="depth_controller" filename="libgazebo_ros_openni_kinect.so">
        <cameraName>d455</cameraName>
        <imageTopicName>/camera/color/image_raw</imageTopicName>
        <depthImageTopicName>/camera/depth/image_raw</depthImageTopicName>
        <pointCloudTopicName>/camera/depth/points</pointCloudTopicName>
        <cameraInfoTopicName>/camera/color/camera_info</cameraInfoTopicName>
        <depthImageCameraInfoTopicName>/camera/depth/camera_info</depthImageCameraInfoTopicName>
        <frameName>camera_depth_optical_frame</frameName>
        <!-- baseline, distortion 参数可省略 -->
        <pointCloudCutoff>0.4</pointCloudCutoff>
        <pointCloudCutoffMax>10.0</pointCloudCutoffMax>
      </plugin>
    </sensor>
  </gazebo>


</robot>